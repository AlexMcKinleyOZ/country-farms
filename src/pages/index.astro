---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WhyFarmland from '../components/WhyFarmland.astro';
import CommunityImpact from '../components/CommunityImpact.astro';
import HowItWorksPreview from '../components/HowItWorksPreview.astro';
import FeaturedProperties from '../components/FeaturedProperties.astro';
import Testimonials from '../components/Testimonials.astro';
import CTABanner from '../components/CTABanner.astro';
