---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const investmentLevels = [
  'まずは情報収集したい',
  '$10,000 未満',
  '$10,000 〜 $50,000',
  '$50,000 〜 $250,000',
  '$250,000 以上',
];

const contactInfo = [
  { icon: '📧', label: 'メール', value: 'hello@countryfarms.co' },
  { icon: '📞', label: '電話', value: '+1 (515) 200-4870' },
  { icon: '📍', label: 'オフィス', value: '218 Main Street, Ames, IA 50010' },
  { icon: '🕐', label: '営業時間', value: '月〜金、午前9時〜午後5時（CST）' },
];

const faqs = [
  {
    q: '誰でも投資できますか？',
    a: '現時点では、米国の認定投資家が対象です。認定投資家とは、一般的に純資産100万ドル超（主たる住居を除く）または年収20万ドル超（共同申告の場合30万ドル超）の方です。非認定投資家向けのReg A+オファリングに向けて積極的に準備を進めています。',
  },
  {
    q: '返答はどのくらいで届きますか？',
    a: 'すべてのお問い合わせには1営業日以内に対応します。投資に関するご質問は、投資家リレーションズチームのメンバーが直接ご連絡します。',
  },
  {
    q: '最低投資額はいくらですか？',
    a: '1物件あたり$1,000から投資可能です。複数の物件への同時投資も上限なく可能です。',
  },
  {
    q: '農場オペレーターとして連携を検討しています。誰に連絡すればよいですか？',
    a: 'ぜひお聞かせください。以下のフォームのメッセージ欄に「農場オペレーターからのお問い合わせ」とお書きいただければ、コミュニティパートナーシップチームが2営業日以内にご連絡します。',
  },
];
---

<Layout
  title="お問い合わせ — Country Farms"
  description="Country Farmsチームへのお問い合わせ。投資、パートナーシップ、プラットフォームに関するご質問はお気軽にどうぞ。"
  lang="ja"
>
  <Nav lang="ja" />

  <main id="main-content">

    <!-- ページヒーロー -->
    <section class="bg-straw py-16 md:py-20" aria-labelledby="contact-heading">
      <div class="cf-container text-center max-w-2xl mx-auto flex flex-col gap-4">
        <h1 id="contact-heading" class="text-h1 text-dark-soil">お問い合わせ</h1>
        <p class="font-dm text-lg leading-[1.7] text-field-brown">
          投資をご検討中の方、情報収集中の方、パートナーをお探しの農場オペレーターの方——どなたからのご連絡もお待ちしています。
        </p>
      </div>
    </section>

    <!-- 2カラム: フォーム + 情報 -->
    <section class="bg-warm-white cf-section" aria-label="お問い合わせフォームと詳細">
      <div class="cf-container grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- フォーム -->
        <div class="lg:col-span-3">
          <form
            name="contact"
            method="POST"
            action="/ja/contact-success"
            class="flex flex-col gap-6"
            aria-labelledby="form-heading"
            novalidate
          >
            <h2 id="form-heading" class="text-h3 text-dark-soil">メッセージを送る</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="name" class="font-dm font-semibold text-sm text-dark-soil">
                  お名前 <span class="text-terracotta" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="山田 太郎"
                  class="font-dm text-[15px] text-dark-soil placeholder:text-field-brown/50
                         rounded-lg border border-wheat bg-white px-4 py-3
                         focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20
                         transition-colors duration-150"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="email" class="font-dm font-semibold text-sm text-dark-soil">
                  メールアドレス <span class="text-terracotta" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="you@example.com"
                  class="font-dm text-[15px] text-dark-soil placeholder:text-field-brown/50
                         rounded-lg border border-wheat bg-white px-4 py-3
                         focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20
                         transition-colors duration-150"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="phone" class="font-dm font-semibold text-sm text-dark-soil">
                電話番号 <span class="font-normal text-field-brown text-xs">（任意）</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                placeholder="+81 90-0000-0000"
                class="font-dm text-[15px] text-dark-soil placeholder:text-field-brown/50
                       rounded-lg border border-wheat bg-white px-4 py-3
                       focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20
                       transition-colors duration-150 max-w-xs"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="investment-level" class="font-dm font-semibold text-sm text-dark-soil">
                ご検討中の投資額
              </label>
              <div class="relative">
                <select
                  id="investment-level"
                  name="investment_level"
                  class="font-dm text-[15px] text-dark-soil rounded-lg border border-wheat bg-white
                         px-4 py-3 w-full appearance-none cursor-pointer
                         focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20
                         transition-colors duration-150"
                >
                  <option value="" disabled selected>金額範囲を選択してください</option>
                  {investmentLevels.map((level) => (
                    <option value={level}>{level}</option>
                  ))}
                </select>
                <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-field-brown text-xs" aria-hidden="true">▼</span>
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="message" class="font-dm font-semibold text-sm text-dark-soil">
                メッセージ <span class="text-terracotta" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                placeholder="ご関心の内容、ご質問、またはお手伝いできることをお聞かせください..."
                class="font-dm text-[15px] text-dark-soil placeholder:text-field-brown/50
                       rounded-lg border border-wheat bg-white px-4 py-3 resize-y
                       focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20
                       transition-colors duration-150"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary self-start">
              送信する →
            </button>
          </form>
        </div>

        <!-- サイドバー -->
        <aside class="lg:col-span-2 flex flex-col gap-8" aria-label="連絡先情報">
          <div class="flex flex-col gap-5">
            <h2 class="text-h3 text-dark-soil">連絡先</h2>
            <ul class="flex flex-col gap-5">
              {contactInfo.map(({ icon, label, value }) => (
                <li class="flex items-start gap-4">
                  <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">{icon}</span>
                  <div>
                    <span class="font-dm font-semibold text-xs uppercase tracking-[0.06em] text-field-brown block">{label}</span>
                    <span class="font-dm text-[15px] text-dark-soil">{value}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-straw border border-wheat rounded-xl p-6 flex flex-col gap-3">
            <span class="text-2xl" aria-hidden="true">⚡</span>
            <p class="font-dm font-semibold text-sm text-dark-soil">1営業日以内にご返信します</p>
            <p class="font-dm text-sm leading-[1.65] text-field-brown">
              すべてのメッセージはチームメンバーが直接確認します。自動応答は使用していません。
            </p>
          </div>

          <div class="bg-dark-soil rounded-xl p-6 flex flex-col gap-4">
            <h3 class="font-lora font-semibold text-base text-warm-white">最新情報を受け取る</h3>
            <p class="font-dm text-sm leading-[1.65] text-warm-white/75">
              新規物件のお知らせ、四半期インパクトレポート、マーケットインサイトをメールでお届けします。
            </p>
            <form class="flex gap-2" aria-label="メルマガ登録">
              <input
                type="email"
                placeholder="メールアドレス"
                aria-label="メルマガ登録用メールアドレス"
                class="font-dm text-sm text-warm-white placeholder:text-warm-white/40 rounded-lg
                       border border-field-brown/30 bg-warm-white/10 px-3 py-2 flex-1 min-w-0
                       focus:outline-none focus:ring-2 focus:ring-terracotta/60
                       transition-colors duration-150"
              />
              <button type="submit" class="btn-primary shrink-0 text-sm px-4 py-2">登録する</button>
            </form>
          </div>
        </aside>
      </div>
    </section>

    <!-- よくある質問 -->
    <section class="bg-straw cf-section" aria-labelledby="contact-faq-heading">
      <div class="cf-container flex flex-col gap-10 max-w-3xl mx-auto">
        <div class="text-center flex flex-col gap-3">
          <h2 id="contact-faq-heading" class="text-h2 text-dark-soil">よくある質問</h2>
          <p class="font-dm text-base text-field-brown">よく寄せられるご質問への回答です。</p>
        </div>

        <div class="flex flex-col divide-y divide-wheat rounded-xl bg-warm-white border border-wheat overflow-hidden cf-card-shadow">
          {faqs.map(({ q, a }) => (
            <details class="group px-6 py-0">
              <summary
                class="flex items-center justify-between gap-4 py-5 cursor-pointer
                       font-dm font-semibold text-[15px] text-dark-soil
                       list-none select-none
                       hover:text-terracotta transition-colors duration-150"
              >
                {q}
                <span
                  class="shrink-0 w-6 h-6 rounded-full border border-wheat flex items-center justify-center
                         text-field-brown text-sm transition-transform duration-200
                         group-open:rotate-45 group-open:text-terracotta group-open:border-terracotta"
                  aria-hidden="true"
                >
                  +
                </span>
              </summary>
              <p class="font-dm text-sm leading-[1.7] text-field-brown pb-5 -mt-1">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer lang="ja" />
</Layout>
