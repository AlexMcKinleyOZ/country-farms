---
import { useTranslations, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).testimonials;
---

<section class="bg-warm-white cf-section" aria-labelledby="testimonials-heading">
  <div class="cf-container flex flex-col gap-12">

    <div class="text-center flex flex-col gap-3">
      <h2 id="testimonials-heading" class="text-h2 text-dark-soil">{t.heading}</h2>
      <p class="font-dm text-base text-field-brown">{t.intro}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {t.items.map(({ quote, name, role, initials, type }) => (
        <figure class="bg-straw border border-wheat rounded-xl p-8 flex flex-col gap-6 cf-card-shadow">
          <span class="font-lora font-bold text-6xl leading-none text-terracotta/30 select-none" aria-hidden="true">
            "
          </span>
          <blockquote>
            <p class="font-dm text-base leading-[1.75] text-dark-soil -mt-8">{quote}</p>
          </blockquote>
          <figcaption class="flex items-center gap-4 border-t border-wheat pt-6 mt-auto">
            <div
              class={`w-11 h-11 rounded-full flex items-center justify-center font-dm font-semibold text-sm shrink-0
                      ${type === 'investor' ? 'bg-terracotta/15 text-terracotta' : 'bg-sage-green/15 text-sage-green'}`}
              aria-hidden="true"
            >
              {initials}
            </div>
            <div>
              <p class="font-dm font-semibold text-[15px] text-dark-soil">{name}</p>
              <p class="font-dm text-sm text-field-brown">{role}</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
