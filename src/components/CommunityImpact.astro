---
import { useTranslations, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).communityImpact;
---

<section class="bg-straw cf-section" aria-labelledby="community-heading">
  <div class="cf-container">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:gap-20">

      <!-- Text column -->
      <div class="flex-1 flex flex-col gap-6">
        <span
          class="self-start font-dm font-semibold text-xs uppercase tracking-[0.08em]
                 text-sage-green bg-sage-green/10 rounded-full px-4 py-1.5"
        >
          {t.badge}
        </span>

        <h2 id="community-heading" class="text-h2 text-dark-soil">
          {t.heading1}<br />{t.heading2}
        </h2>

        <p class="font-dm text-base leading-[1.7] text-field-brown max-w-lg">{t.body}</p>

        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-2">
          {t.pillars.map(({ icon, label }) => (
            <li class="flex items-center gap-3 font-dm text-[15px] font-medium text-dark-soil">
              <span aria-hidden="true">{icon}</span>
              {label}
            </li>
          ))}
        </ul>

        <a href={lang === 'ja' ? '/ja/about' : '/about'} class="btn-primary self-start mt-2">
          {t.cta}
        </a>
      </div>

      <!-- Visual column -->
      <div class="flex-1 max-w-[480px] lg:max-w-none mx-auto lg:mx-0" aria-hidden="true">
        <div class="flex flex-col gap-4">
          {t.stats.map(({ num, unit, sub }) => (
            <div class="bg-warm-white rounded-xl px-6 py-5 flex items-center gap-5 cf-card-shadow">
              <p class="font-lora font-bold text-3xl text-terracotta shrink-0 w-24">{num}</p>
              <div>
                <p class="font-dm font-semibold text-[15px] text-dark-soil">{unit}</p>
                <p class="font-dm text-sm text-field-brown">{sub}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
