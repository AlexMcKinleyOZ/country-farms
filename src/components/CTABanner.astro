---
import { useTranslations, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang).ctaBanner;
---

<section class="bg-terracotta py-20" aria-labelledby="cta-heading">
  <div class="cf-container text-center flex flex-col items-center gap-6">

    <h2 id="cta-heading" class="font-lora font-bold text-white"
        style="font-size: clamp(1.75rem, 0.6rem + 2.86vw, 2.5rem); line-height: 1.2;">
      {t.heading1}<br class="hidden sm:block" /> {t.heading2}
    </h2>

    <p class="font-dm text-base text-white/80 max-w-md leading-[1.7]">{t.body}</p>

    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={lang === 'ja' ? '/ja/contact' : '/contact'}
        class="inline-flex items-center justify-center gap-2
               bg-white text-terracotta font-dm font-semibold text-[15px]
               px-7 py-3.5 rounded-lg border-none cursor-pointer
               transition-all duration-150 hover:bg-warm-white hover:-translate-y-px"
      >
        {t.primaryCta}
      </a>
      <a
        href={lang === 'ja' ? '/ja/how-it-works' : '/how-it-works'}
        class="inline-flex items-center justify-center gap-2
               bg-transparent text-white font-dm font-semibold text-[15px]
               px-7 py-3.5 rounded-lg border border-white/50 cursor-pointer
               transition-all duration-150 hover:bg-white/10 hover:-translate-y-px"
      >
        {t.secondaryCta}
      </a>
    </div>

  </div>
</section>
